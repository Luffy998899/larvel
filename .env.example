APP_NAME=RevactylHost
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=revactyl_host
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PTERO_URL=https://panel.example.com
PTERO_API_KEY=ptla_xxx
PTERO_NODE_ID=1
PTERO_EGG_ID=5
PTERO_LOCATION_ID=1
PTERO_DEFAULT_NEST_ID=1
PTERO_DEFAULT_DOCKER_IMAGE=ghcr.io/pterodactyl/yolks:java_17

AD_WEBHOOK_SECRET=change-me

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!
